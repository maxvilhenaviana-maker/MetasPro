{
  "rewrites": [
    { "source": "/api/onboarding/(.*)", "destination": "/api/onboarding.js" },
    { "source": "/api/metas/(.*)",      "destination": "/api/metas.js"      },
    { "source": "/api/(.*)",            "destination": "/api/index.js"      },
    { "source": "/(.*)",                "destination": "/index.html"        }
  ]
}
